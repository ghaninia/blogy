# =============================================================================
# GH Blog — environment template
# Copy: cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gh_blog
POSTGRES_PORT=5432

# --- Database URL ---
# Local (pnpm dev + docker compose up db):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gh_blog?schema=public
# Docker full stack (backend uses compose override to db:5432 automatically)

# --- API ---
API_PORT=4000
API_URL=http://localhost:4000
NODE_ENV=development
JWT_ACCESS_SECRET=dev-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=dev-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=http://localhost:3000

# --- Web (Dashboard) ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Media ---
# Local pnpm dev:
UPLOAD_DIR=../../uploads
# Docker (set automatically in compose): UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# --- Docker runtime (backend entrypoint) ---
RUN_SEED=true
DB_HOST=db
DB_PORT=5432
