# Development backend with hot reload

FROM node:20-alpine

RUN apk add --no-cache libc6-compat openssl netcat-openbsd curl
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY src/backend/package.json ./src/backend/
COPY src/packages/ui/package.json ./src/packages/ui/

RUN pnpm install --frozen-lockfile

COPY docker/scripts/entrypoint-backend.dev.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 4000

ENTRYPOINT ["/entrypoint.sh"]
CMD ["pnpm", "--filter", "@gh/backend", "dev"]
